# =============================================================================
# Outur AI — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Outur AI"
APP_ENV="development"          # development | staging | production
APP_VERSION="0.1.0"
APP_DEBUG=true
APP_SECRET_KEY="CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32"

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST="0.0.0.0"
PORT=8000
WORKERS=1                       # Increase for production
RELOAD=true                     # Set false in production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_HOST="localhost"
DATABASE_PORT=5432
DATABASE_NAME="outur_ai"
DATABASE_USER="outur"
DATABASE_PASSWORD="CHANGE_ME"
DATABASE_URL="postgresql+asyncpg://outur:CHANGE_ME@localhost:5432/outur_ai"

# Pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL="INFO"                # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"               # json | console
LOG_FILE=""                     # Leave empty to disable file logging

# -----------------------------------------------------------------------------
# Google Antigravity / Gemini
# -----------------------------------------------------------------------------
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"
ANTIGRAVITY_ENV="local"         # local | cloud
GEMINI_MODEL="gemini-2.0-flash-exp"

# -----------------------------------------------------------------------------
# Authentication / Security
# -----------------------------------------------------------------------------
JWT_SECRET_KEY="CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# External APIs (add as agents require them)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# APOLLO_API_KEY=""
# HUNTER_API_KEY=""
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Redis (future: task queue / caching)
# -----------------------------------------------------------------------------
# REDIS_URL="redis://localhost:6379/0"

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS='["http://localhost:3000","http://localhost:8000"]'
CORS_ALLOW_CREDENTIALS=true
